---
import Layout from '../layouts/Layout.astro';
import AnnouncementCard from '../components/AnnouncementCard.astro';
import announcementsData from '../content/announcements.json';

const recentAnnouncements = announcementsData.items.slice(0, 3);
---

<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-court"></div>
    <div class="hero-tag">Pleasanton, CA · Tri-Valley CYO League</div>
    <h1>
      Play<br/>
      <span class="accent">Hard.</span><br/>
      <span class="stroke">Grow</span><br/>
      Together.
    </h1>
    <p class="hero-sub">
      CCOP CYO Basketball — where kids in grades 3–8 learn the game, build character, and make lifelong memories. Everyone plays. Everyone improves. Everyone's welcome.
    </p>
    <div class="hero-buttons">
      <a href="/registration" class="btn-primary">Register for 2025–26</a>
      <a href="/announcements" class="btn-secondary">League News</a>
    </div>
    <div class="hero-stats">
      <div class="stat-item">
        <div class="stat-num">3rd–8th</div>
        <div class="stat-label">Grades</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">55+</div>
        <div class="stat-label">Years of CYO</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">5</div>
        <div class="stat-label">Tri-Valley Cities</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">All</div>
        <div class="stat-label">Faiths Welcome</div>
      </div>
    </div>
  </section>

  <!-- ANNOUNCEMENTS PREVIEW -->
  <section class="announcements-section">
    <div class="section-inner">
      <div class="fade-in">
        <div class="section-label">League News</div>
        <div class="section-title">Latest Announcements</div>
      </div>
      <div class="announcements-grid">
        {recentAnnouncements.map((item) => (
          <AnnouncementCard {...item} />
        ))}
      </div>
      <div class="fade-in" style="margin-top: 2.5rem;">
        <a href="/announcements" class="btn-secondary" style="border-color: rgba(10,22,40,0.25); color: var(--navy);">View All Announcements →</a>
      </div>
    </div>
  </section>

  <!-- REGISTRATION TEASER -->
  <section class="registration-section">
    <div class="section-inner">
      <div class="reg-layout">
        <div class="reg-info fade-in">
          <div class="section-label">Join the Team</div>
          <div class="section-title">Register for the 2025–26 Season</div>
          <p>Open to boys and girls in <strong>grades 3–8</strong> living in Pleasanton or Sunol. No prior experience needed — players of all skill levels are welcome!</p>
          <div class="fee-badge">
            Early Bird: <strong>$350</strong> &nbsp;|&nbsp; Regular: <strong>$375</strong>
          </div>
          <div class="reg-details">
            <div class="reg-detail-row">
              <div class="detail-icon">📅</div>
              <div>
                <div class="detail-label">Key Dates</div>
                <div class="detail-value">Evaluations: mid-September · Practices: October · Games: Late Oct – mid-Feb</div>
              </div>
            </div>
            <div class="reg-detail-row">
              <div class="detail-icon">🏀</div>
              <div>
                <div class="detail-label">Practice & Games</div>
                <div class="detail-value">2 practices/week · Games on Sunday afternoons throughout the Tri-Valley area</div>
              </div>
            </div>
            <div class="reg-detail-row">
              <div class="detail-icon">📍</div>
              <div>
                <div class="detail-label">Locations</div>
                <div class="detail-value">St. Elizabeth's Gym + Pleasanton middle school gyms · Pleasanton, Danville, Dublin, San Ramon, Livermore</div>
              </div>
            </div>
            <div class="reg-detail-row">
              <div class="detail-icon">⛪</div>
              <div>
                <div class="detail-label">Open to All</div>
                <div class="detail-value">All faiths and beliefs welcome — no Catholic affiliation required</div>
              </div>
            </div>
          </div>
        </div>

        <div class="reg-cta-card fade-in">
          <h3>Ready to Sign Up?</h3>
          <p>Registration fills up fast. Secure your child's spot for the upcoming season.</p>
          <a href="/registration" class="btn-primary reg-cta-btn">Register Now →</a>
          <a href="/contact" class="btn-secondary reg-cta-btn">Have Questions? Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="gallery-section">
    <div class="section-inner">
      <div class="gallery-header fade-in">
        <div>
          <div class="section-label">Team Moments</div>
          <div class="section-title">Photo Gallery</div>
        </div>
      </div>
      <div class="gallery-grid fade-in">
        <div class="gallery-item">
          <div class="gallery-placeholder">
            <div class="icon">🏀</div>
            <div class="label">Game Day Action</div>
          </div>
          <div class="gallery-item-overlay">
            <div class="gallery-caption">Game Day · Jan 2026</div>
          </div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">
            <div class="icon">🏆</div>
            <div class="label">Tournament Win</div>
          </div>
          <div class="gallery-item-overlay">
            <div class="gallery-caption">Holiday Tournament</div>
          </div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">
            <div class="icon">🤝</div>
            <div class="label">Team Huddle</div>
          </div>
          <div class="gallery-item-overlay">
            <div class="gallery-caption">Pre-game Huddle</div>
          </div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">
            <div class="icon">⭐</div>
            <div class="label">Skills Practice</div>
          </div>
          <div class="gallery-item-overlay">
            <div class="gallery-caption">Practice · St. Elizabeth's</div>
          </div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">
            <div class="icon">📸</div>
            <div class="label">Team Photo</div>
          </div>
          <div class="gallery-item-overlay">
            <div class="gallery-caption">Season Team Photo</div>
          </div>
        </div>
      </div>
      <div class="gallery-upload fade-in">
        <p>📸 &nbsp;<strong>Got great photos from a game or practice?</strong> &nbsp;Share them with the league! <a href="/contact" style="color: var(--orange);">Contact us</a> to have your photos featured here.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .reg-cta-card {
    background: rgba(232, 232, 228, 0.05);
    border: 1px solid rgba(232, 232, 228, 0.12);
    border-top: 5px solid var(--orange);
    border-radius: 12px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .reg-cta-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.8rem;
    text-transform: uppercase;
    color: var(--white);
  }
  .reg-cta-card p {
    color: var(--gray-light);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .reg-cta-btn { width: 100%; text-align: center; }
</style>
