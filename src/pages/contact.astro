---
import Layout from '../layouts/Layout.astro';
import contactData from '../content/contact.json';
---

<Layout title="Contact | CCOP CYO Basketball">
  <div class="page-header">
    <div class="page-header-inner">
      <div class="section-label">Get in Touch</div>
      <h1 class="page-title">Contact Us</h1>
    </div>
  </div>

  <section>
    <div class="section-inner">
      <div class="contact-layout fade-in">
        <div class="contact-info">
          <div class="section-label">Reach Out</div>
          <div class="section-title" style="margin-bottom: 1.5rem;">We'd Love to<br/>Hear From You</div>
          <div class="contact-details">
            {contactData.details.map((d) => (
              <div class="reg-detail-row">
                <div class="detail-icon">{d.icon}</div>
                <div>
                  <div class="detail-label">{d.label}</div>
                  <div class="detail-value">
                    {d.isEmail ? (
                      <a href={`mailto:${d.value}`} class="contact-link">{d.value}</a>
                    ) : (
                      d.value
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="reg-form-card">
          <h3>Send a Message</h3>
          <p>Questions about registration, schedules, or anything else? We'll get back to you quickly.</p>
          <form name="contact" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden-field"><label>Don't fill this out: <input name="bot-field" /></label></p>
            <div class="form-row">
              <div class="form-field">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" placeholder="Jane Smith" required />
              </div>
              <div class="form-field">
                <label for="contact-email">Email</label>
                <input type="email" id="contact-email" name="email" placeholder="jane@email.com" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field full">
                <label for="subject">Subject</label>
                <input type="text" id="subject" name="subject" placeholder="Registration question, schedule inquiry, etc." />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field full">
                <label for="message">Message</label>
                <textarea id="message" name="message" placeholder="Tell us how we can help..." required></textarea>
              </div>
            </div>
            <button type="submit" class="form-submit">Send Message →</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }
  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }
  .contact-link { color: var(--orange); text-decoration: none; }
  .contact-link:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .contact-layout { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
