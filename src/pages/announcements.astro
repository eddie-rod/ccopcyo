---
import Layout from '../layouts/Layout.astro';
import AnnouncementCard from '../components/AnnouncementCard.astro';
import announcementsData from '../content/announcements.json';
const announcements = announcementsData.items;
---

<Layout title="Announcements | CCOP CYO Basketball">
  <div class="page-header">
    <div class="page-header-inner">
      <div class="section-label">League News</div>
      <h1 class="page-title">Announcements</h1>
    </div>
  </div>

  <section class="announcements-section">
    <div class="section-inner">
      <div class="announcements-grid">
        {announcements.map((item) => (
          <AnnouncementCard {...item} />
        ))}
      </div>
      {announcements.length === 0 && (
        <p class="empty-state">No announcements yet. Check back soon!</p>
      )}
    </div>
  </section>
</Layout>

<style>
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--gray-mid);
    font-size: 1rem;
  }
</style>
